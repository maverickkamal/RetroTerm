{
  "manifest_version": 3,
  "name": "RetroTerm",
  "version": "1.0.0",
  "description": "Transforms GitHub, Hack Club, and Carnival into amber CRT terminal experiences.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["shared/boot.js", "content/github/github.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://hackclub.com/*"],
      "js": ["shared/boot.js", "content/hackclub/hackclub.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://carnival.hackclub.com/*"],
      "js": ["shared/boot.js", "content/carnival/carnival.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/retro-base.css",
        "content/github/github.css",
        "content/hackclub/hackclub.css",
        "content/carnival/carnival.css"
      ],
      "matches": ["https://github.com/*", "https://hackclub.com/*", "https://carnival.hackclub.com/*"]
    }
  ]
}
